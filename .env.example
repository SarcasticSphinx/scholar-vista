# ============================================================================
# ScholarVista — Environment Variables (example)
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for local development.
# Never commit `.env` (already covered by .gitignore — `.env*`).
# All values below are intentionally empty/placeholder; do not commit secrets.
# ============================================================================

# ----------------------------------------------------------------------------
# Database (NeonDB / PostgreSQL)
# Required. Use Neon's pooled connection string in production (`-pooler`).
# ----------------------------------------------------------------------------
DATABASE_URL=

# ----------------------------------------------------------------------------
# Better Auth
# BETTER_AUTH_SECRET: required, min 32 chars. Generate: `openssl rand -base64 32`
# BETTER_AUTH_URL: required, full origin where the app is hosted.
# ----------------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# ----------------------------------------------------------------------------
# Public app URL (exposed to the browser, used by the Better Auth client)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=

# ----------------------------------------------------------------------------
# Google OAuth (optional — enables Google sign-in)
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# UploadThing (optional — enables image uploads)
# ----------------------------------------------------------------------------
UPLOADTHING_TOKEN=
UPLOADTHING_SECRET=

# ----------------------------------------------------------------------------
# Stripe (optional — enables paid scholarship checkout)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Cron secret (optional — protects scheduled job endpoints, e.g. payment expiry)
# ----------------------------------------------------------------------------
CRON_SECRET=
